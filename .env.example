# API Keys
OPENROUTER_API_KEY=your_openrouter_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Model Configuration
FAST_MODEL=openrouter/google/gemini-2.0-flash-lite-preview-02-05:free
VISION_MODEL=openrouter/openai/gpt-4o-mini

# Budget Controls
MAX_COST_PER_DOCUMENT=1.00
MAX_PAGES_FOR_VISION=50
WARN_AT_COST=0.50

# Storage Paths
DATA_DIR=./data
REFINERY_DIR=./.refinery
PROFILES_DIR=./.refinery/profiles
PAGEINDEX_DIR=./.refinery/pageindex
LEDGER_DIR=./.refinery/ledger

# Vector Store
VECTOR_STORE_TYPE=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./.refinery/refinery.log