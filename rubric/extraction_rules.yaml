# 📋 Document Intelligence Refinery - Extraction Rules Configuration
# Externalized rules allow new document types without code changes
# Version: 1.0
# Last Updated: 2026-03-04

# ============================================
# 1. DOCUMENT CLASSIFICATION THRESHOLDS
# ============================================
# Based on Phase 0 analysis of 471 pages across 4 document classes
# Validation: Class B (24 chars) → Scanned, Class C (3646 chars) → Digital

classification:
  character_density:
    scanned_max_chars: 50      # Below this → definitely scanned (Class B: 24)
    digital_min_chars: 100     # Above this → definitely digital (Class C: 3646)
    mixed_range: [50, 100]     # Between → mixed, need sampling
    
  image_ratio:
    scanned_min_ratio: 0.5     # Class B: 0.803 image ratio
    digital_max_ratio: 0.3     # Class C: 0.001 image ratio
    
  layout_complexity:
    multi_column_min_clusters: 2   # Different x-position clusters
    table_detection:
      min_vertical_lines: 2        # Lines indicating table
      min_horizontal_lines: 2
      min_cell_alignment: 0.7      # Text alignment score

# ============================================
# 2. STRATEGY SELECTION RULES
# ============================================
# Maps document profile to extraction strategy

strategy_routing:
  scanned:
    - condition: "character_density < 50 AND image_ratio > 0.5"
      strategy: "vision"
      reason: "Pure scanned document needs OCR/VLM"
      
  digital_simple:
    - condition: "character_density > 100 AND image_ratio < 0.3 AND NOT has_tables AND NOT multi_column"
      strategy: "fast_text"
      reason: "Simple digital document - fast extraction sufficient"
      
  digital_complex:
    - condition: "character_density > 100 AND (has_tables OR multi_column)"
      strategy: "layout_aware"
      reason: "Complex layout needs structure preservation"
      
  mixed:
    - condition: "character_density BETWEEN 50 AND 100"
      action: "sample_first_3_pages"
      fallback_strategy: "layout_aware"
      reason: "Mixed content - sample then decide"

# ============================================
# 3. CONFIDENCE THRESHOLDS & ESCALATION
# ============================================
# The escalation guard - heart of intelligent routing

confidence:
  fast_text:
    min_confidence: 0.7           # Below this → escalate to layout_aware
    escalation_target: "layout_aware"
    signals:
      character_density_weight: 0.4
      image_ratio_weight: 0.3
      font_consistency_weight: 0.3
      
  layout_aware:
    min_confidence: 0.8           # Below this → escalate to vision
    escalation_target: "vision"
    signals:
      table_completeness_weight: 0.4
      reading_order_accuracy: 0.3
      bbox_preservation: 0.3
      
  vision:
    min_confidence: 0.9           # Below this → fallback with warning
    max_retries: 2
    signals:
      text_extraction_quality: 0.5
      structure_preservation: 0.5

# ============================================
# 4. EXTRACTION TOOL CONFIGURATION
# ============================================

tools:
  fast_text:
    primary: "pdfplumber"
    fallback: "pymupdf"
    options:
      pages: "first_5_for_analysis"
      extract_tables: true
      preserve_bbox: true
      
  layout_aware:
    primary: "docling"
    version: "2.8.0"              # Pinned to avoid API mismatches
    fallback: "mineru"
    options:
      max_pages: 50                # Prevent memory issues
      do_ocr: true
      do_table_structure: true
      page_limit: 10               # For analysis mode
      
  vision:
    provider: "openrouter"
    models:
      cheap: "openai/gpt-4o-mini"
      accurate: "google/gemini-pro-vision"
      fallback: "anthropic/claude-3-haiku"
    options:
      max_pages: 20                 # Budget control
      cost_warning: 0.50            # Alert at $0.50
      max_cost_per_doc: 1.00        # Hard stop

# ============================================
# 5. SEMANTIC CHUNKING RULES
# ============================================
# The "Constitution" for data quality - 5 enforceable rules

chunking:
  rules:
    - id: "RULE_001"
      name: "no_table_split"
      description: "Table cells must never be split from their header row"
      priority: 1
      enforcement: "strict"
      validation: "verify_table_integrity"
      
    - id: "RULE_002"
      name: "figure_caption_linked"
      description: "Figure caption stored as metadata of parent figure"
      priority: 1
      enforcement: "strict"
      validation: "verify_figure_caption_binding"
      
    - id: "RULE_003"
      name: "list_preservation"
      description: "Numbered lists kept as single LDU unless exceeds max_tokens"
      priority: 2
      max_tokens: 512
      enforcement: "warning"
      
    - id: "RULE_004"
      name: "section_hierarchy"
      description: "Section headers stored as parent metadata on all child chunks"
      priority: 1
      enforcement: "strict"
      validation: "verify_hierarchy_integrity"
      
    - id: "RULE_005"
      name: "cross_reference_resolved"
      description: "Cross-references (e.g., 'see Table 3') resolved and stored as relationships"
      priority: 3
      enforcement: "best_effort"
      
  ldu_config:
    max_tokens: 1024
    min_tokens: 50
    overlap_tokens: 0               # No overlap - semantic boundaries only
    chunk_types:
      - "text"
      - "table"
      - "figure"
      - "list"
      - "section_header"

# ============================================
# 6. PROVENANCE REQUIREMENTS
# ============================================

provenance:
  required_fields:
    - "document_name"
    - "page_number"
    - "bounding_box"               # x1,y1,x2,y2 coordinates
    - "content_hash"                # SHA-256 of content + position
    
  content_hash_algorithm: "sha256"
  include_in_every_answer: true
  audit_mode:
    verify_on_query: true
    mismatch_threshold: 0.85        # Fuzzy match threshold
    log_unverified: true

# ============================================
# 7. COST MANAGEMENT & BUDGET CONTROLS
# ============================================

budget:
  max_cost_per_document_usd: 1.00    # Hard cap
  warn_at_cost_usd: 0.50             # Warning threshold
  max_pages_for_vision: 50            # Prevent bill shock
  
  cost_per_page:
    fast_text: 0.001                  # $0.001/page
    layout_aware: 0.01                # $0.01/page
    vision: 0.10                       # $0.10/page
    
  logging:
    log_every_extraction: true
    log_cost_breakdown: true
    ledger_path: ".refinery/extraction_ledger.jsonl"

# ============================================
# 8. SAMPLING & ANALYSIS CONFIGURATION
# ============================================

sampling:
  initial_analysis_pages: 5           # Pages to sample for triage
  confidence_sampling_pages: 3         # Pages to check for escalation
  mixed_document_sample_size: 3        # Pages to sample for mixed docs
  
  heuristics:
    check_fonts: true
    check_text_blocks: true
    check_images: true
    check_tables: true

# ============================================
# 9. ERROR HANDLING & FALLBACKS
# ============================================

error_handling:
  max_retries: 3
  retry_delay_seconds: 2
  
  fallback_chain:
    - from: "fast_text"
      to: "layout_aware"
      on: ["low_confidence", "extraction_failed", "empty_output"]
      
    - from: "layout_aware"
      to: "vision"
      on: ["low_confidence", "api_error", "memory_error", "version_mismatch"]
      
    - from: "vision"
      to: "fallback_logging"
      on: ["budget_exceeded", "api_failure", "timeout"]
      
  logging:
    log_all_failures: true
    log_escalations: true
    log_cost_overruns: true

# ============================================
# 10. DOCUMENT-SPECIFIC OVERRIDES
# ============================================
# Allow client-specific configurations

document_overrides:
  - pattern: "*audit*.pdf"
    force_strategy: "vision"
    reason: "Audit documents often scanned"
    
  - pattern: "*tax*.pdf"
    force_strategy: "layout_aware"
    reason: "Tax documents have complex tables"
    
  - pattern: "*annual*.pdf"
    force_strategy: "layout_aware"
    reason: "Annual reports have multi-column layouts"